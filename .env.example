# ─── Kuboo CRM · variáveis de ambiente ───────────────────────────────────────
# Copie para `.env` (local) ou configure no Vercel. NUNCA comite o `.env` real.

# ── Público (client, prefixo VITE_ — vai pro bundle, pode ser exposto) ────────
# Supabase: Project Settings > API. A anon/publishable key é pública por design
# (a segurança real é o RLS no banco, não o segredo da chave).
VITE_SUPABASE_URL=https://uqzenphlvxncuwjzufmo.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# ── Privado (server, SÓ nas Serverless Functions do Vercel — NUNCA com VITE_) ──
# Chave privilegiada do Supabase (service_role ou a nova sb_secret_). Ignora RLS:
# usada só pelo api/clientes.js pra criar login de cliente. Se vazar, é game over.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# Trello Power-Up (api/trello.js). key = pública do app; token = autorização da conta.
# https://trello.com/power-ups/admin  ·  https://trello.com/1/authorize
TRELLO_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRELLO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
